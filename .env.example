# ─────────────────────────────────────────────────────────────────────────────
# Digital Nomad Summit — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── [A] REQUIRED FOR PRODUCTION ─────────────────────────────────────────────

# Airtable — Partners & Influencers workspace
# Used by: lib/airtable.ts → getActivePartners(), getActiveInfluencers()
# Surfaces: Partners/Sponsors section, Influencer Collective section
AIRTABLE_API_KEY=your_airtable_pat_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Partners

# Supabase — DNS Backend Temporal (Partners & Influencers)
# Used by: lib/data/partners.ts, lib/data/influencers.ts
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Airtable — Speakers workspace (separate base)
# Used by: lib/airtable-speakers.ts → getSpeakers(), getSpeakerBySlug()
# Surfaces: /speakers page, /speakers/[slug] page, Homepage Speakers section,
#           Featured Speakers API route (/api/featured-speakers)
AIRTABLE_API_KEY_SPEAKER=your_speaker_airtable_pat_token_here
AIRTABLE_BASE_ID_SPEAKER=your_speaker_airtable_base_id_here
AIRTABLE_TABLE_NAME_SPEAKER=Speakers

# ─── [B] OPTIONAL BUT RECOMMENDED ────────────────────────────────────────────

# Vercel Blob — used for any uploaded assets stored in Vercel Blob storage
# If not set, blob-stored images simply won't load
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Vercel Web Analytics — enables the analytics dashboard on Vercel
# Auto-injected by Vercel if @vercel/analytics is installed; safe to omit locally
VERCEL_WEB_ANALYTICS_ID=your_vercel_analytics_id_here

# ─── [C] STALE / V0-SPECIFIC — DO NOT ADD TO PRODUCTION VERCEL PROJECT ───────

# These were injected by the v0 runtime and are not used by any production code.
# Do NOT add these to your Vercel project environment variables.

# ANTHROPIC_AUTH_TOKEN    — v0 AI tooling only
# AI_GATEWAY_API_KEY      — v0 AI tooling only
# V0_CALLBACK_URL         — v0 runtime only
# V0_CODE_SERVER_CALLBACK_URL — v0 runtime only
# VERCEL_OIDC_TOKEN       — auto-injected by Vercel CI, not needed manually

# ─────────────────────────────────────────────────────────────────────────────
# AI Guide Agent (DNS 2026)
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key at https://console.groq.com/
GROQ_API_KEY=
