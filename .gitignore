# ─── Next.js generated ───────────────────────────────────────────────────────
.next/
out/

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Environment variables (NEVER commit secrets) ────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── v0 runtime artifacts (safe to ignore) ────────────────────────────────────
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
dev.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── TypeScript build info ────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
